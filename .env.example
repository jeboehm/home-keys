# Random secret for HMAC session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32

# Home Assistant
HA_URL=http://homeassistant:8123
HA_TOKEN=your-long-lived-access-token-from-ha

# Required: set your Home Assistant helper entity IDs.
# ENTITY_UNLOCK_ALLOWANCE is an input_boolean that enables or disables door unlocking.
# ENTITY_DOOR_CODE is an input_text that holds the numeric login PIN (leave empty in HA to disable PIN).
ENTITY_UNLOCK_ALLOWANCE=input_boolean.home_keys_enabled
ENTITY_DOOR_CODE=input_text.home_keys_code

# Optional: comma-separated entity IDs to exclude from the dashboard
# IGNORED_ENTITIES=lock.some_entity,lock.another

# Optional: listening address (default: :8080)
# LISTEN_ADDR=:8080
